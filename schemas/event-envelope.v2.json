{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-memory-fabric.dev/schemas/event-envelope.v2.json",
  "title": "Agentic Memory Fabric Event Envelope v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "sequence",
    "timestamp",
    "actor",
    "tenant_id",
    "memory_id",
    "event_type",
    "previous_events",
    "payload_hash"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "timestamp": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wall_time"
      ],
      "properties": {
        "wall_time": {
          "type": "string",
          "format": "date-time"
        },
        "tick": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "user",
            "service",
            "tool"
          ]
        },
        "display_name": {
          "type": "string"
        },
        "invocation_id": {
          "type": "string"
        }
      }
    },
    "memory_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "enum": [
        "created",
        "updated",
        "superseded",
        "recalled",
        "reconsolidated",
        "quarantined",
        "released",
        "expired",
        "deleted",
        "imported",
        "attested"
      ]
    },
    "previous_events": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
      },
      "uniqueItems": true
    },
    "payload_hash": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "payload": {},
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "ref"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "url",
              "message_id",
              "file_path",
              "tool_run_id",
              "opaque"
            ]
          },
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "digest": {
            "type": "string"
          }
        }
      }
    },
    "trust_transition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "to"
      ],
      "properties": {
        "from": {
          "type": "string",
          "enum": [
            "trusted",
            "quarantined",
            "expired"
          ]
        },
        "to": {
          "type": "string",
          "enum": [
            "trusted",
            "quarantined",
            "expired"
          ]
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "alg",
        "key_id",
        "sig"
      ],
      "properties": {
        "alg": {
          "type": "string",
          "enum": [
            "hmac-sha256",
            "ed25519"
          ]
        },
        "key_id": {
          "type": "string",
          "minLength": 1
        },
        "sig": {
          "type": "string",
          "pattern": "^[A-Za-z0-9+/=]+$"
        }
      }
    },
    "attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issuer",
        "issued_at",
        "trust_level"
      ],
      "properties": {
        "issuer": {
          "type": "string",
          "minLength": 1
        },
        "issued_at": {
          "type": "string",
          "format": "date-time"
        },
        "trust_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "claims": {
          "type": "object"
        }
      }
    }
  }
}
